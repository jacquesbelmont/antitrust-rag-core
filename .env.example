# ──────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in real values
# NEVER commit .env to version control
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=legalrag
POSTGRES_USER=legalrag
POSTGRES_PASSWORD=CHANGEME_strong_password_here

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGEME_strong_redis_password

# ── Weaviate ───────────────────────────────────────────────────────────────────
# Override only if running Weaviate outside Docker (e.g. managed cloud)
WEAVIATE_URL=http://weaviate:8080

# ── Ollama (LLM + Embeddings) ──────────────────────────────────────────────────
# Ollama runs on the host machine — host.docker.internal resolves to the host
# from within Docker containers on macOS/Windows; use host IP on Linux.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_LLM_MODEL=mistral
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── RAG Pipeline ───────────────────────────────────────────────────────────────
RAG_RETRIEVAL_TOP_K_DEFAULT=5
RAG_MAX_CHUNK_CHARS=1400
RAG_CHUNK_OVERLAP_CHARS=120
RAG_ENABLE_RERANKING=true

# ── API service ────────────────────────────────────────────────────────────────
API_PORT=8000
LOG_LEVEL=INFO

# ── Flower (Celery monitoring UI) ──────────────────────────────────────────────
FLOWER_PORT=5555
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGEME_flower_password

# ── Worker ─────────────────────────────────────────────────────────────────────
CELERY_CONCURRENCY=4
